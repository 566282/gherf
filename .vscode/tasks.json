{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "platform: dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/platform"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "platform: build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}/platform"
      },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "platform: typecheck",
      "type": "shell",
      "command": "npm",
      "args": ["run", "typecheck"],
      "options": {
        "cwd": "${workspaceFolder}/platform"
      },
      "problemMatcher": ["$tsc"]
    }
  ]
}